# Copy to .env (gitignored). Every value is optional — the server runs with none of them set.

# Port the Express server listens on.
PORT=3000

# Absolute origin of the vMCP data API the liveness probes read from.
# Leave EMPTY for same-origin (/vmcp/api) — that is the local/compose deployment.
# Set it when the front end and the API are on different hostnames.
VMCP_API_BASE=

# Discord webhook that receives the optional "Who are you?" greeting from the home page.
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL.
# Left empty, greetings are logged to stdout instead of being relayed. This URL is a CREDENTIAL:
# anyone holding it can post to your channel. Never commit it.
DISCORD_WEBHOOK_URL=
