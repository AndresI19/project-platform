{
  "name": "portfolio-home",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Personal home page + project index, served behind the platform reverse proxy at /.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx src/server/index.ts",
    "serve": "npm run build && npm start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src"
  },
  "dependencies": {
    "@platform/ui": "file:packages/platform-ui",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "happy-dom": "^15.11.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
