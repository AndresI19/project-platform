{
  "name": "portfolio-home",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal home page + project index, served behind the platform reverse proxy at /.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx src/server/index.ts",
    "serve": "npm run build && npm start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
