{
  "name": "platform-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Identity for the platform: a memorable code, exchanged for a signed JWT.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "keygen": "tsx scripts/keygen.ts",
    "lint": "biome check src"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.1",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
